      "title": "USB Data Drives (/var/mnt/usb)"
    },
    {
      "contextLinks": {"linksData": []},
      "description": "Bytes used on /var/mnt/usb per node (beelink=jellyfin-media XFS, rpi5=MinIO data)",
      "fillSpans": false,
      "id": "usb-bytes",
      "isStacked": false,
      "nullZeroValues": "null",
      "panelTypes": "graph",
      "query": {
        "builder": {"queryData": [], "queryFormulas": []},
        "clickhouse_sql": [{"disabled": false, "legend": "", "name": "A", "query": ""}],
        "promql": [
          {
            "disabled": false,
            "legend": "{{k8s.node.name}}",
            "name": "A",
            "query": "sum by (\"k8s.node.name\") ({\"system.filesystem.usage\", state=\"used\", mountpoint=\"/var/mnt/usb\"})"
          }
        ],
        "queryType": "promql"
      },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "softMax": 0,
      "softMin": 0,
      "thresholds": [],
      "timePreferance": "GLOBAL_TIME",
      "title": "USB Drive Used Space",
      "yAxisUnit": "bytes"
    },
    {
      "contextLinks": {"linksData": []},
      "description": "Percentage of /var/mnt/usb used per node",
      "fillSpans": false,
      "id": "usb-pct",
      "isStacked": false,
      "nullZeroValues": "null",
      "panelTypes": "graph",
      "query": {
        "builder": {"queryData": [], "queryFormulas": []},
        "clickhouse_sql": [{"disabled": false, "legend": "", "name": "A", "query": ""}],
        "promql": [
          {
            "disabled": false,
            "legend": "{{k8s.node.name}}",
            "name": "A",
            "query": "sum by (\"k8s.node.name\") ({\"system.filesystem.usage\", state=\"used\", mountpoint=\"/var/mnt/usb\"}) / (sum by (\"k8s.node.name\") ({\"system.filesystem.usage\", state=\"used\", mountpoint=\"/var/mnt/usb\"}) + sum by (\"k8s.node.name\") ({\"system.filesystem.usage\", state=\"free\", mountpoint=\"/var/mnt/usb\"})) * 100"
          }
        ],
        "queryType": "promql"
      },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "softMax": 100,
      "softMin": 0,
      "thresholds": [
        {
          "thresholdColor": "Yellow",
          "thresholdFormat": "1",
          "thresholdOperator": ">",
          "thresholdUnit": "percent",
          "thresholdValue": 80
        },
        {
          "thresholdColor": "Red",
          "thresholdFormat": "1",
          "thresholdOperator": ">",
          "thresholdUnit": "percent",
          "thresholdValue": 90
        }
      ],
      "timePreferance": "GLOBAL_TIME",
      "title": "USB Drive Usage %",
      "yAxisUnit": "percent"
