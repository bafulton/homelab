    {
      "contextLinks": {"linksData": []},
      "description": "Cabinet temperature from Meross MTS960 thermostat (sensor.mts960_844f_current_temperature) and its cooling setpoint",
      "fillSpans": false,
      "id": "cabinet-temp",
      "isStacked": false,
      "nullZeroValues": "null",
      "panelTypes": "graph",
      "query": {
        "builder": {"queryData": [], "queryFormulas": []},
        "clickhouse_sql": [{"disabled": false, "legend": "", "name": "A", "query": ""}],
        "promql": [
          {
            "disabled": false,
            "legend": "Cabinet (actual)",
            "name": "A",
            "query": "{\"homeassistant_sensor_temperature_celsius\", entity=\"sensor.mts960_844f_current_temperature\"}"
          },
          {
            "disabled": false,
            "legend": "Target",
            "name": "B",
            "query": "{\"homeassistant_climate_target_temperature_celsius\", entity=\"climate.mts960_844f_heater_cooler\"}"
          }
        ],
        "queryType": "promql"
      },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "softMax": 50,
      "softMin": 0,
      "thresholds": [
        {"thresholdColor": "Yellow", "thresholdFormat": "1", "thresholdOperator": ">", "thresholdUnit": "none", "thresholdValue": 40},
        {"thresholdColor": "Red", "thresholdFormat": "1", "thresholdOperator": ">", "thresholdUnit": "none", "thresholdValue": 45}
      ],
      "timePreferance": "GLOBAL_TIME",
      "title": "Cabinet Temperature (\u00b0C)",
      "yAxisUnit": "celsius"
    },
    {
      "contextLinks": {"linksData": []},
