            "disabled": false,
            "filter": {
              "expression": ""
            },
            "groupBy": [
              {
                "name": "k8s.node.name",
                "signal": "",
                "fieldContext": "attribute",
                "fieldDataType": "string"
              }
            ],
            "having": {
