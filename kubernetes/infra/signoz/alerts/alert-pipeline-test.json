{
  "alert": "SigNoz Alerting Pipeline Down",
  "alertType": "METRIC_BASED_ALERT",
  "version": "v5",
  "severity": "critical",
  "ruleType": "threshold_rule",
  "evalWindow": "15m0s",
  "frequency": "1m0s",
  "broadcastToAll": true,
  "preferredChannels": [
    "Email"
  ],
  "disabled": false,
  "description": "No k8s.node.cpu.usage data for 10+ minutes. SigNoz metrics ingestion or the alerting pipeline is broken.",
  "summary": "SigNoz alerting pipeline is DOWN",
  "labels": {
    "source": "gitops",
    "severity": "critical"
  },
  "condition": {
    "compositeQuery": {
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "stepInterval": 60,
            "signal": "metrics",
            "source": "",
            "aggregations": [
              {
                "metricName": "k8s.node.cpu.usage",
                "temporality": "",
                "timeAggregation": "avg",
                "spaceAggregation": "avg",
                "reduceTo": ""
              }
            ],
            "disabled": false,
            "filter": {
              "expression": ""
            },
            "groupBy": [],
            "having": {
              "expression": ""
            },
            "legend": "cpu.usage"
          }
        }
      ],
      "panelType": "graph",
      "queryType": "builder"
    },
    "op": "1",
    "target": 1000000,
    "matchType": "1",
    "selectedQueryName": "A",
    "alertOnAbsent": true,
    "absentFor": 10
  },
  "notificationSettings": {
    "renotify": {
      "enabled": false
    }
  }
}
