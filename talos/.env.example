# Talos Configuration Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is gitignored to prevent secrets from being committed.

# Tailscale OAuth client credentials (from https://login.tailscale.com/admin/settings/oauth)
# Create an OAuth client with:
#   - Scopes: devices:core, auth_keys
#   - Tags: e.g., tag:k8s-node
# OAuth clients don't expire, making them more reliable than pre-auth keys for node authentication.
TS_CLIENT_ID=
TS_CLIENT_SECRET=
